<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="default"/>
<meta name="theme-color" content="#ffffff"/>
<title>LawnApp – Crew</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --green:#3B6D11;--green-bg:#EEF5E8;
  --blue:#185FA5;--info-bg:#EEF3FB;
  --red:#C0392B;--red-bg:#FDEDED;
  --amber:#BA7517;--amber-bg:#FEF6E7;
  --text:#1A1A18;--text2:#4A4845;--text3:#9E9B97;
  --border:#E0DDD8;--card:#FFFFFF;--bg:#F7F5F2;
  --safe-bot:env(safe-area-inset-bottom,0px);
}
html,body{height:100%;background:var(--bg);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:var(--text)}
#app{height:100%;display:flex;flex-direction:column;max-width:430px;margin:0 auto;background:var(--card);box-shadow:0 0 40px rgba(0,0,0,.08)}

/* SCREENS */
.screen{display:none;flex-direction:column;flex:1;overflow:hidden}
.screen.active{display:flex}
.screen-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:12px 16px 16px}

/* HEADER */
.hdr{display:flex;align-items:center;gap:8px;padding:12px 16px;border-bottom:0.5px solid var(--border);flex-shrink:0;background:var(--card)}
.hdr-title{font-size:17px;font-weight:700;flex:1}

/* NAV */
.bnav{display:flex;border-top:0.5px solid var(--border);background:var(--card);padding-bottom:var(--safe-bot);flex-shrink:0;position:relative;z-index:10}
.bnav-btn{flex:1;display:flex;flex-direction:column;align-items:center;padding:8px 4px 6px;border:none;background:none;font-size:10px;color:var(--text3);cursor:pointer;gap:2px}
.bnav-btn.active{color:var(--blue)}
.bnav-icon{font-size:22px;line-height:1}

/* WEEK NAV */
.wk-nav{display:flex;align-items:center;justify-content:space-between;padding:8px 16px;border-bottom:0.5px solid var(--border);flex-shrink:0}
.wk-btn{background:none;border:0.5px solid var(--border);border-radius:8px;padding:5px 12px;font-size:14px;cursor:pointer;color:var(--text2)}
.wk-range{font-size:13px;font-weight:600;color:var(--text2)}
.wk-strip{display:flex;gap:4px;padding:8px 16px;overflow-x:auto;flex-shrink:0;background:var(--card);border-bottom:0.5px solid var(--border)}
.dp{display:flex;flex-direction:column;align-items:center;padding:6px 8px;border-radius:10px;cursor:pointer;min-width:40px;flex-shrink:0;background:none}
.dp.hj{background:var(--info-bg)}
.dp.pj{background:#FFF3E0}
.dp.hj.pj{background:linear-gradient(90deg,var(--info-bg) 50%,#FFF3E0 50%)}
.dp.pj .dp-n,.dp.pj .dp-d,.dp.pj .dp-c{color:#E65100}
.dp.sel{background:transparent;box-shadow:0 0 0 2px var(--blue)}
.dp.sel .dp-n,.dp.sel .dp-d,.dp.sel .dp-c{color:var(--blue)!important}
.dp-n{font-size:10px;color:var(--text3);font-weight:500}
.dp-d{font-size:16px;font-weight:700;color:var(--text)}
.dp-c{font-size:10px;color:var(--blue);font-weight:600;min-height:14px}

/* JOB CARDS */
.jcard{background:var(--card);border:0.5px solid var(--border);border-left:4px solid var(--blue);border-radius:12px;padding:10px 12px;margin-bottom:8px}
.jrow{display:flex;align-items:flex-start;gap:10px}
.jinfo{flex:1}
.jloc{font-size:15px;font-weight:700;color:var(--text)}
.jloc-name{font-size:15px;font-weight:700;color:var(--text)}
.jloc-addr{font-size:12px;color:var(--text3);margin-top:1px}
.badges{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px}
.badge{font-size:11px;font-weight:600;padding:3px 8px;border-radius:10px;background:var(--info-bg);color:var(--blue)}
.jnote{font-size:12px;color:var(--text3);margin-top:4px;font-style:italic}
.slbl{font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin:12px 0 6px}
.empty{text-align:center;padding:40px 20px;color:var(--text3);font-size:14px;line-height:1.6}

/* ITEMS CHECKLIST */
.items-banner{background:#FFFBF0;border:1px solid #F0D080;border-radius:10px;padding:10px 12px;margin-bottom:8px}
.item-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:0.5px solid #E8E4DB}
.item-check{width:20px;height:20px;border-radius:4px;border:1.5px solid var(--blue);background:none;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px}
.item-check.done{background:var(--green);border-color:var(--green)}
.item-text{font-size:13px;flex:1;color:var(--text)}
.item-text.done{color:var(--text3);text-decoration:line-through}

/* SHEETS */
#modal-root{}
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:100;display:flex;align-items:flex-end;justify-content:center}
.sheet{background:var(--card);border-radius:20px 20px 0 0;padding:20px 16px 32px;width:100%;max-width:430px;max-height:85vh;overflow-y:auto}
.sheet-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 16px}
.sheet-title{font-size:18px;font-weight:700;margin-bottom:16px}
.fl{font-size:12px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-top:14px;margin-bottom:6px}
input[type=text],input[type=number]{width:100%;padding:10px 12px;border:0.5px solid var(--border);border-radius:10px;font-size:15px;background:var(--bg);color:var(--text);font-family:inherit}
.btn-row{display:flex;gap:8px;margin-top:16px}
.btn-cancel{flex:1;padding:12px;border:0.5px solid var(--border);border-radius:10px;background:none;font-size:15px;cursor:pointer;color:var(--text2)}
.btn-save{flex:2;padding:12px;border:none;border-radius:10px;background:var(--blue);color:#fff;font-size:15px;font-weight:600;cursor:pointer}
.btn-outline{width:100%;padding:11px;border:0.5px solid var(--border);border-radius:10px;background:none;font-size:14px;cursor:pointer;color:var(--text2)}
.chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:4px}
.chip{padding:7px 14px;border:0.5px solid var(--border);border-radius:20px;font-size:13px;cursor:pointer;background:none;color:var(--text2)}
.chip.on{background:var(--blue);color:#fff;border-color:var(--blue)}

/* SYNC BANNER */
.sync-banner{display:flex;align-items:center;gap:8px;padding:8px 16px;background:var(--amber-bg);border-bottom:0.5px solid #F0D080;font-size:12px;color:var(--amber);flex-shrink:0}

/* MAINT CARD */
.maint-card{background:#FEF6E7;border:0.5px solid #F0C060;border-left:4px solid var(--amber);border-radius:10px;padding:10px 12px;margin-bottom:6px;display:flex;align-items:flex-start;gap:8px}

/* PROJECT BANNER */
.proj-banner{background:#FFF3E0;border-left:3px solid #E65100;border-radius:8px;padding:10px 12px;margin-bottom:6px}

/* TOAST */
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:#1A1A18;color:#fff;padding:10px 20px;border-radius:20px;font-size:14px;z-index:200;white-space:nowrap;pointer-events:none}
</style>
</head>
<body>
<div id="app">

  <!-- SCHEDULE SCREEN -->
  <div class="screen active" id="scr-schedule">
    <div class="hdr">
      <div class="hdr-title" id="sched-title">Today</div>
      <div style="flex:1"></div>
      <span id="sync-status" style="font-size:12px;color:var(--text3)">☁️</span>
      <button onclick="pullData()" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0 4px">🔄</button>
    </div>
    <div class="mnav" style="display:flex;align-items:center;justify-content:space-between;padding:8px 16px;border-bottom:0.5px solid var(--border);flex-shrink:0">
      <button class="wk-btn" onclick="changeDay(-1)">‹</button>
      <span id="sched-date-lbl" style="font-size:14px;font-weight:600;color:var(--text2)"></span>
      <button class="wk-btn" onclick="changeDay(1)">›</button>
    </div>
    <div class="screen-body" id="sched-body"></div>
  </div>

  <!-- UPCOMING SCREEN -->
  <div class="screen" id="scr-upcoming">
    <div class="hdr">
      <div class="hdr-title">Upcoming</div>
      <div style="flex:1"></div>
      <button onclick="pullData()" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0 4px">🔄</button>
    </div>
    <div class="wk-nav">
      <button class="wk-btn" onclick="if(fwOff>0){fwOff--;renderUpcoming()}">‹ Prev</button>
      <span class="wk-range" id="wk-range"></span>
      <button class="wk-btn" onclick="fwOff++;renderUpcoming()">Next ›</button>
    </div>
    <div class="wk-strip" id="wk-strip"></div>
    <div class="screen-body" id="up-body"></div>
  </div>

  <!-- NAV -->
  <div class="bnav">
    <button class="bnav-btn active" id="nav-schedule" onclick="goScreen('schedule')">
      <div class="bnav-icon">📋</div><span>Schedule</span>
    </button>
    <button class="bnav-btn" id="nav-upcoming" onclick="goScreen('upcoming')">
      <div class="bnav-icon">📅</div><span>Upcoming</span>
    </button>
  </div>
</div>

<div id="modal-root"></div>

<script>
// ─── CONFIG ──────────────────────────────────────────────────────
const JBIN_KEY = '$2a$10$uq8Z.wsWpmuLkNPnOOj4vORzEQ//vdajt9uMTJZdVNJbJ8YuzgqgW';
const JBIN_BIN = '69dc48abaaba882197f147b1';

// ─── STATE ───────────────────────────────────────────────────────
const SVC_COLOR = {Lawncare:'#3B6D11',Treework:'#854F0B',Mulching:'#5F5E5A',Landscaping:'#185FA5',Maintenance:'#BA7517'};
let SC = {}, HW = {}, MAINT = [], PROFILES = [], SVCS = ['Lawncare','Treework','Mulching','Landscaping','Maintenance'];
let PROJECTS = [], CL = {};
let viewKey, selUpKey, fwOff = 0, curScreen = 'schedule';
let _nid = 9000;
const uid = () => String(_nid++);

// ─── DATE HELPERS ────────────────────────────────────────────────
function toKey(d){ return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
function addDays(d,n){ const r=new Date(d); r.setDate(r.getDate()+n); return r; }
function wkStart(d){ const r=new Date(d); r.setDate(r.getDate()-r.getDay()); return toKey(r); }
function fmtDate(k){ if(!k) return ''; const d=new Date(k+'T12:00:00'); return ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()]+', '+['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()]+' '+d.getDate(); }

const TODAY = toKey(new Date());

function profileNameFor(j){
  if(j.profileName && j.profileName !== j.loc) return {name:j.profileName, addr:j.loc};
  const p = PROFILES.find(p=>p.loc===j.loc&&p.service===j.service);
  if(p&&p.name&&p.name!==j.loc) return {name:p.name, addr:j.loc};
  return {name:j.loc, addr:null};
}

function gS(k){ return SC[k]||[]; }
function gCL(k){ if(!CL[k]) CL[k]=[]; return CL[k]; }
function getProjectsForDay(k){
  return PROJECTS.filter(p=>{
    if(p.status!=='active') return false;
    const s=p.startDate||'', e=p.endDate||'9999-12-31';
    return k>=s && k<=e;
  });
}

// ─── CLOUD ───────────────────────────────────────────────────────
async function pullData(){
  document.getElementById('sync-status').textContent = '⏳';
  try{
    const r = await fetch('https://api.jsonbin.io/v3/b/'+JBIN_BIN+'/latest',{
      headers:{'X-Master-Key':JBIN_KEY}
    });
    const j = await r.json();
    const d = j.record || j;
    if(d && d.SC){
      SC={}; Object.assign(SC,d.SC||{});
      HW={}; Object.assign(HW,d.HW||{});
      MAINT=d.MAINT||[];
      PROFILES=d.PROFILES||[];
      SVCS=d.SVCS||SVCS;
      PROJECTS=d.PROJECTS||[];
      CL={}; Object.assign(CL,d.CL||{});
      renderSchedule();
      renderUpcoming();
      document.getElementById('sync-status').textContent = '☁️';
      showToast('✓ Updated');
    }
  }catch(e){
    document.getElementById('sync-status').textContent = '⚠️';
    showToast('Could not connect');
  }
}

async function pushData(){
  // Only push CL changes (checklist) — all other data is read-only
  try{
    const r = await fetch('https://api.jsonbin.io/v3/b/'+JBIN_BIN+'/latest',{
      headers:{'X-Master-Key':JBIN_KEY}
    });
    const j = await r.json();
    const d = j.record || j;
    // Merge CL changes into full snapshot
    d.CL = CL;
    // Also merge item done states back
    if(d.SC){
      Object.keys(SC).forEach(k=>{
        if(d.SC[k]){
          d.SC[k].forEach((dj,i)=>{
            const lj = (SC[k]||[]).find(x=>x.id===dj.id);
            if(lj) d.SC[k][i].items = lj.items;
          });
        }
      });
    }
    // Also merge PROJECTS item states
    if(d.PROJECTS && PROJECTS.length){
      d.PROJECTS.forEach((dp,i)=>{
        const lp = PROJECTS.find(x=>x.id===dp.id);
        if(lp) d.PROJECTS[i].items = lp.items;
      });
    }
    await fetch('https://api.jsonbin.io/v3/b/'+JBIN_BIN,{
      method:'PUT',
      headers:{'Content-Type':'application/json','X-Master-Key':JBIN_KEY},
      body: JSON.stringify(d)
    });
  }catch(e){ console.warn('Push failed',e); }
}

// ─── NAVIGATION ──────────────────────────────────────────────────
function goScreen(name){
  document.getElementById('scr-'+name).classList.add('active');
  document.getElementById('nav-'+name).classList.add('active');
  document.querySelectorAll('.screen').forEach(s=>{ if(s.id!=='scr-'+name) s.classList.remove('active'); });
  document.querySelectorAll('.bnav-btn').forEach(b=>{ if(b.id!=='nav-'+name) b.classList.remove('active'); });
  curScreen = name;
  if(name==='schedule') renderSchedule();
  if(name==='upcoming') renderUpcoming();
}

function changeDay(n){
  const d = new Date(viewKey+'T12:00:00');
  viewKey = toKey(addDays(d, n));
  renderSchedule();
}

// ─── SCHEDULE RENDER ─────────────────────────────────────────────
function renderSchedule(){
  const k = viewKey;
  document.getElementById('sched-title').textContent = k===TODAY ? 'Today' : fmtDate(k);
  document.getElementById('sched-date-lbl').textContent = fmtDate(k);

  let html = '';

  // Items needed banner (checklist + important job items)
  html += renderItemsBanner(k);

  // Project banners
  const projs = getProjectsForDay(k);
  projs.forEach(p=>{
    const items = p.items||[];
    const undone = items.filter(it=>!it.done);
    const done = items.filter(it=>it.done);
    const allItems = [...undone,...done];
    const itemRows = allItems.map(it=>`
      <div class="item-row">
        <button class="item-check ${it.done?'done':''}" onclick="toggleProjItem('${p.id}','${it.id}')">${it.done?'✓':''}</button>
        <span class="item-text ${it.done?'done':''}">${it.important?'⚠️ ':''}${it.text}</span>
      </div>`).join('');
    html += `<div class="proj-banner">
      <div style="display:flex;justify-content:space-between;align-items:center${allItems.length?';margin-bottom:6px':''}">
        <div>
          <div style="font-size:14px;font-weight:700;color:#E65100">🏗️ ${p.name}</div>
          ${p.category?`<div style="font-size:12px;color:#BF360C">${p.category}</div>`:''}
        </div>
        <button onclick="openAddItemSheet('proj','${p.id}','${k}')" style="font-size:11px;color:#E65100;background:none;border:0.5px solid #E65100;border-radius:6px;padding:3px 8px;cursor:pointer">+ Item</button>
      </div>
      ${allItems.length?`<div>${itemRows}</div>`:''}
    </div>`;
  });

  // Jobs
  const jobs = gS(k).filter(j=>!j.skipped);
  const active = jobs.filter(j=>!j.done);
  const done = jobs.filter(j=>j.done);

  if(!jobs.length && !projs.length){
    html += '<div class="empty">No jobs scheduled today.</div>';
  }
  if(active.length){ html += '<div class="slbl">Scheduled</div>'; active.forEach(j=>{ html += jobCard(j,k,false); }); }
  if(done.length){ html += '<div class="slbl">Completed</div>'; done.forEach(j=>{ html += jobCard(j,k,true); }); }

  // Maintenance
  const maint = MAINT.filter(m=>m.date===k);
  if(maint.length){
    html += '<div class="slbl">Maintenance</div>';
    maint.forEach(m=>{
      html += `<div class="maint-card">
        <div style="width:8px;height:8px;border-radius:50%;background:var(--amber);margin-top:4px;flex-shrink:0"></div>
        <div><div style="font-size:14px;font-weight:600;color:#854F0B">${m.item}</div>
        ${m.machine?`<div style="font-size:12px;color:var(--amber)">${m.machine}</div>`:''}
        ${m.notes?`<div style="font-size:12px;color:var(--text3)">${m.notes}</div>`:''}</div>
      </div>`;
    });
  }

  document.getElementById('sched-body').innerHTML = html;
}

function jobCard(j, k, isDone){
  const pn = profileNameFor(j);
  const sc = SVC_COLOR[j.service]||'#888';
  const items = j.items||[];
  const undone = items.filter(it=>!it.done);
  const doneItems = items.filter(it=>it.done);
  const allItems = [...undone,...doneItems];

  const itemRows = allItems.map(it=>`
    <div class="item-row">
      <button class="item-check ${it.done?'done':''}" onclick="toggleJobItem('${j.id}','${it.id}','${k}')">${it.done?'✓':''}</button>
      <span class="item-text ${it.done?'done':''}">${it.important?'⚠️ ':''}${it.text}</span>
    </div>`).join('');

  return `<div class="jcard" style="border-left-color:${sc};opacity:${isDone?'.6':'1'}">
    <div class="jrow">
      <div class="jinfo">
        ${pn.addr?`<div class="jloc-name">${pn.name}</div><div class="jloc-addr">${pn.addr}</div>`:`<div class="jloc">${pn.name}</div>`}
        <div class="badges">
          <span class="badge" style="background:${sc}22;color:${sc}">${j.service}</span>
          ${isDone?'<span class="badge" style="background:var(--green-bg);color:var(--green)">✓ Done</span>':''}
        </div>
        ${j.note?`<div class="jnote">${j.note}</div>`:''}
        ${allItems.length?`<div style="margin-top:8px;border-top:0.5px solid var(--border);padding-top:6px">${itemRows}</div>`:''}
      </div>
      <button onclick="openAddItemSheet('job','${j.id}','${k}')" style="flex-shrink:0;background:none;border:0.5px solid var(--blue);color:var(--blue);border-radius:8px;padding:4px 8px;font-size:11px;cursor:pointer;white-space:nowrap">+ Item</button>
    </div>
  </div>`;
}

// ─── UPCOMING RENDER ─────────────────────────────────────────────
function renderUpcoming(){
  const ws = wkStart(addDays(new Date(), fwOff*7));
  const wsDate = new Date(ws+'T12:00:00');
  const wkEnd = addDays(wsDate, 6);
  const ML = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  document.getElementById('wk-range').textContent = ML[wsDate.getMonth()]+' '+wsDate.getDate()+' – '+ML[wkEnd.getMonth()]+' '+wkEnd.getDate();

  const strip = Array.from({length:7},(_,i)=>{
    const d = addDays(wsDate,i), k = toKey(d);
    const has = SC[k]&&SC[k].length>0;
    const isSel = k===selUpKey;
    const isToday = k===TODAY;
    const hasProj = getProjectsForDay(k).length>0;
    return `<div class="dp${has?' hj':''}${hasProj?' pj':''}${isSel?' sel':''}" onclick="selUpKey='${k}';renderUpcoming()">
      <div style="font-size:9px;text-align:center;color:var(--red);line-height:1;margin-bottom:1px">${isToday?'▼':''}</div>
      <div class="dp-n">${['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()]}</div>
      <div class="dp-d">${d.getDate()}</div>
      <div class="dp-c">${SC[k]&&SC[k].length?SC[k].length:''}</div>
    </div>`;
  }).join('');
  document.getElementById('wk-strip').innerHTML = strip;

  const k = selUpKey;
  const jobs = gS(k).filter(j=>!j.skipped);
  const projs = getProjectsForDay(k);
  let html = '';

  projs.forEach(p=>{
    html += `<div class="proj-banner" style="margin-bottom:8px">
      <div style="font-size:14px;font-weight:700;color:#E65100">🏗️ ${p.name}</div>
      ${p.category?`<div style="font-size:12px;color:#BF360C">${p.category}</div>`:''}
      ${p.endDate?`<div style="font-size:11px;color:#8D6E63">Until ${fmtDate(p.endDate)}</div>`:''}
    </div>`;
  });

  if(!jobs.length && !projs.length){
    html += '<div class="empty">No jobs this day.</div>';
  }

  jobs.forEach(j=>{
    const pn = profileNameFor(j);
    const sc = SVC_COLOR[j.service]||'#888';
    html += `<div class="jcard" style="border-left-color:${sc}">
      <div class="jrow">
        <div class="jinfo">
          ${pn.addr?`<div class="jloc-name">${pn.name}</div><div class="jloc-addr">${pn.addr}</div>`:`<div class="jloc">${pn.name}</div>`}
          <div class="badges"><span class="badge" style="background:${sc}22;color:${sc}">${j.service}</span></div>
          ${j.note?`<div class="jnote">${j.note}</div>`:''}
        </div>
      </div>
    </div>`;
  });

  document.getElementById('up-body').innerHTML = html;
}

// ─── ITEMS BANNER ────────────────────────────────────────────────
function renderItemsBanner(k){
  const dayItems = gCL(k);
  const jobImportant = gS(k).filter(j=>!j.skipped).flatMap(j=>
    (j.items||[]).filter(it=>it.important).map(it=>({...it,jid:j.id,fromJob:profileNameFor(j).name}))
  );
  const allUndone = [...dayItems.filter(it=>!it.done).map(it=>({...it,src:'day'})), ...jobImportant.filter(it=>!it.done).map(it=>({...it,src:'job'}))];
  const allDone   = [...dayItems.filter(it=>it.done).map(it=>({...it,src:'day'})), ...jobImportant.filter(it=>it.done).map(it=>({...it,src:'job'}))];
  if(!allUndone.length && !allDone.length) return '';

  const makeRow = (it) => {
    const checkFn = it.src==='day'
      ? `toggleDayItem('${k}','${it.id}')`
      : `toggleJobItem('${it.jid}','${it.id}','${k}')`;
    return `<div class="item-row">
      <button class="item-check ${it.done?'done':''}" onclick="${checkFn}">${it.done?'✓':''}</button>
      <span class="item-text ${it.done?'done':''}">${it.text}</span>
      ${it.fromJob?`<span style="font-size:11px;color:var(--text3)">${it.fromJob}</span>`:''}
    </div>`;
  };

  return `<div class="items-banner">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
      <div style="font-size:11px;font-weight:700;color:#8B6914;text-transform:uppercase;letter-spacing:.06em">📝 Items Needed</div>
      <button onclick="openAddItemSheet('day','','${k}')" style="font-size:11px;color:var(--blue);background:none;border:none;cursor:pointer">+ Add</button>
    </div>
    ${allUndone.map(makeRow).join('')}
    ${allDone.length?'<div style="font-size:10px;color:#8B6914;margin-top:4px;margin-bottom:2px">Done</div>'+allDone.map(makeRow).join(''):''}
  </div>`;
}

// ─── TOGGLE ITEMS ────────────────────────────────────────────────
function toggleDayItem(k, id){
  const it = gCL(k).find(x=>x.id===id);
  if(it){ it.done=!it.done; pushData(); renderSchedule(); }
}

function toggleJobItem(jid, itemId, k){
  const j = gS(k).find(x=>x.id===jid);
  if(!j) return;
  const it = (j.items||[]).find(x=>x.id===itemId);
  if(it){ it.done=!it.done; pushData(); renderSchedule(); }
}

function toggleProjItem(projId, itemId){
  const p = PROJECTS.find(x=>x.id===projId);
  if(!p) return;
  const it = (p.items||[]).find(x=>x.id===itemId);
  if(it){ it.done=!it.done; pushData(); renderSchedule(); }
}

// ─── ADD ITEM SHEET ──────────────────────────────────────────────
function openAddItemSheet(type, id, k){
  showSheet(`
    <div class="sheet-title">Add Item</div>
    <div class="fl" style="margin-top:0">Item description</div>
    <input type="text" id="new-item-text" placeholder="e.g. Bring extra bags"/>
    <label style="display:flex;align-items:center;gap:8px;margin-top:12px;font-size:14px;cursor:pointer">
      <input type="checkbox" id="new-item-imp" style="width:18px;height:18px"/> ⚠️ Mark as important
    </label>
    <div class="btn-row" style="margin-top:16px">
      <button class="btn-cancel" onclick="closeSheet()">Cancel</button>
      <button class="btn-save" onclick="saveNewItem('${type}','${id}','${k}')">Add Item</button>
    </div>
  `);
  setTimeout(()=>document.getElementById('new-item-text')?.focus(), 150);
}

function saveNewItem(type, id, k){
  const text = (document.getElementById('new-item-text')?.value||'').trim();
  if(!text){ alert('Enter an item'); return; }
  const imp = document.getElementById('new-item-imp')?.checked||false;
  const item = {id:uid(), text, important:imp, done:false};

  if(type==='day'){
    gCL(k).push(item);
  } else if(type==='job'){
    const j = gS(k).find(x=>x.id===id);
    if(j){ if(!j.items) j.items=[]; j.items.push(item); }
  } else if(type==='proj'){
    const p = PROJECTS.find(x=>x.id===id);
    if(p){ if(!p.items) p.items=[]; p.items.push(item); }
  }

  pushData();
  closeSheet();
  renderSchedule();
  showToast('Item added');
}

// ─── SHEET HELPERS ───────────────────────────────────────────────
function showSheet(html){
  const root = document.getElementById('modal-root');
  const ov = document.createElement('div');
  ov.className = 'overlay';
  ov.innerHTML = `<div class="sheet"><div class="sheet-handle"></div>${html}</div>`;
  ov.addEventListener('click', e=>{ if(e.target===ov) closeSheet(); });
  root.appendChild(ov);
}
function closeSheet(){
  const root = document.getElementById('modal-root');
  const last = root.lastChild; if(last) last.remove();
}
function showToast(msg){
  const t = document.createElement('div');
  t.className = 'toast'; t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(()=>t.remove(), 2500);
}

